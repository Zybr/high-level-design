@startuml
'https://plantuml.com/component-diagram


'package "Some Group" {
'  HTTP - [First Component]
'  [Another Component]
'}
'
'node "Other Groups" {
'  FTP - [Second Component]
'  [First Component] --> FTP
'}
'
'cloud {
'  [Example 1]
'}
'
'
'database "MySql" {
'  folder "This is my folder" {
'    [Folder 3]
'  }
'  frame "Foo" {
'    [Frame 4]
'  }
'}


'[Another Component] --> [Example 1]
'[Example 1] --> [Folder 3]
'[Folder 3] --> [Frame 4]

package Workers {
}

queue Jobs {
}
object Job {
    + url: String
    + updatedAt: String | null
}
Jobs o-- Job

database Cache {
}
object Link {
    + url:String
    + updatedAt: Timestamp | Null
}
Cache *-- Link

database DB {
}
object Content {
    + url: String
    + data: String | Null
    + createdAt: Timestamp
    + updatedAt: Timestamp | Null
}
DB *-- Content

component ContentManager {
}
() SaveContent
() SaveUrl
() getOutdated
SaveContent -- ContentManager
SaveUrl -- ContentManager
getOutdated -- ContentManager
ContentManager <--> DB
ContentManager <--> Cache

component Planner {
}

Planner <.. getOutdated: get next Link
Planner --> Jobs: create Job

Workers <.. Jobs: get Job
Workers --> SaveContent: save Content(Page)
Workers --> SaveUrl: save Url only



@enduml