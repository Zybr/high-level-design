@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

Person(User, "User")

Container(Gateway, "Gateway")
Container(RateLimiter, "RateLimiter")
Container(WebServers, "Web servers")

Rel(User, Gateway, "Request")
Rel(Gateway, RateLimiter, "Request")
Rel(RateLimiter, WebServers, "Request")

@enduml